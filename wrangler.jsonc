{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "via-baltica",
  "main": "worker/index.ts",
  "compatibility_date": "2026-05-02",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
    "run_worker_first": false
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
